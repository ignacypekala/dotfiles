{
    "Makefile Standard Template": {
        "prefix": "st",
        "body": [
            "IN ?= ${1:main.c}",
            "",
            "# Scraped by DAP",
            "OUT ?= ${2:a.out} ",
            "INPUT ?= ${3:test.in}",
            "",
            "build : \\$(IN)",
            "\tgcc \\$(IN) -o \\$(OUT)",
            "\t",
            "# Ran by DAP",
            "build-debug : \\$(IN)",
            "\tgcc -g \\$(IN) -o \\$(OUT)",
            "",
            "test : \\$(OUT) \\$(INPUT)",
            "\t./\\$(OUT) < \\$(INPUT)",
            "\t",
            "valgrind : \\$(OUT) \\$(INPUT)",
            "\tvalgrind \\$(OUT) --leak-check=full -q  < \\$(INPUT)",
            "",
            "# Ran by DAP",
            "clean : \\$(OUT)",
            "\trm \\$(OUT)",
            ""
        ],
        "description": "Standard Makefile for C debugging"
    }
}
