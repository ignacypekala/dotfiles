### Variables
# Logo key
set $mod Mod4

set $left h
set $down j
set $up k
set $right l

# set $term "wezterm -e tmux-home.sh"
set $term wezterm
set $menu wmenu-run

include ~/.config/sway/config.d/*.conf

### Output configuration
set $wallpaper "~/wallpapers/copenhagen-harbor-by-moonligh.jpg"

output * {
    background $wallpaper fill
}

output DP-2 {
    resolution 1920x1080@240Hz 
    position 0 0
}
output DP-4 {
    resolution 1920x1080 
    position 1920 0 transform "270"
}

focus output DP-2

### Idle configuration
exec swayidle -w \
         timeout 300 'swaylock -f -c 000000' \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -f -c 000000'

### Input configuration

input type:keyboard {
    xkb_layout "pl"
}

### Behaviour
focus_follows_mouse no
focus_on_window_activation focus

# Mod + drag to move/resize
floating_modifier $mod normal

exec_always autotiling

### Layout
default_border pixel 3
gaps outer 5
gaps inner 10

client.focused $white $background $foreground $background $white
client.focused_inactive $white $dim_background $dim_foreground $bright_black $bright_black
client.unfocused $white $dim_background $dim_foreground $bright_black $bright_black


bar {
    position top

# When the status_command prints a new line to stdout, swaybar updates.
# The default just shows the current date and time.
        status_command while date +'%Y-%m-%d %X'; do sleep 1; done

        colors {
            statusline $foreground
                focused_background $background
                background $dim_background
                focused_workspace $background $primary $black
                active_workspace $background $white $black
                inactive_workspace $background $bright_black $foreground
        }
}

include /etc/sway/config.d/*
